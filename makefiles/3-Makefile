RM = rm
NAME = school
OBJ = $(SRC:.c=.o)
CC = gcc
SRC = main.c school.c
all: $(OBJ)
	$(CC) $(OBJ) -o $(NAME)
clean :
	rm -f *~ $(NAME)
oclean :
	rm -f $(OBJ)
fclean  :
	rm -f *~ $(NAME)
	rm -f $(OBJ)
re :
	$(CC)    -c -o main.o main.c
	$(CC)    -c -o school.o school.c
	$(CC) main.o school.o -o school
